{
  "name": "mala",
  "private": true,
  "scripts": {
    "qa": "start-server-and-test \"serve . -l 3000\" http://localhost:3000 \"playwright test --config .github/qa/playwright.config.js\"",
    "qa:headed": "start-server-and-test \"serve . -l 3000\" http://localhost:3000 \"playwright test --config .github/qa/playwright.config.js --headed\"",
    "qa:report": "playwright show-report playwright-report",
    "qa:html": "html-validate --config .github/qa/.htmlvalidate.json index.html",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@playwright/test": "^1.44.0",
    "html-validate": "^9.4.0",
    "serve": "^14.2.3",
    "start-server-and-test": "^2.0.3",
    "wait-on": "^7.2.0"
  }
}
